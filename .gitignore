# Environments
.env
.env.*
!.env.example
.venv
venv/
env/
ENV/
bin/
lib/
share/
include/
pyvenv.cfg
pip-selfcheck.json

# Tooling
node_modules/
.pyre/
.pytest_cache/
.vscode/
__pycache__/
*.pyc

# Clinical Data (Keep local unless explicitly intended for cloud)
audit_log.json
memory.json
prior_auth_store.json
*.faiss
*.pkl

# Security: never commit local credential material or secret-bearing config files.
config/credentials.json
config/*.json
*.pem
*.key
*.p12
secrets/

# Logs
logs/
*.log

# Misc
.DS_Store
.input_history
frontend.pid

# CMS-AUD-01: signed daily Merkle roots are durable artifacts uploaded to
# GCS Object Lock in production. Locally we generate them at runtime; we
# only commit the README explaining the directory.
storage/audit_roots/*.json
storage/audit_roots/*.json.tmp
