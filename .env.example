# Security (required — generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=changeme_min_32_chars
BUDDI_STORAGE_KEY=changeme_min_16_chars
API_KEY=changeme_api_key

# Database (required)
DATABASE_URL=postgresql://buddi_user:yourpassword@localhost:5432/buddi
# Optional override of the runtime DB role granted RLS privileges during
# the 7a3c8d9f0142 migration. Falls back to current_user when unset.
BUDDI_DB_ROLE=

# CORS (required — comma-separated, no wildcards)
CORS_ORIGINS=http://localhost:5173

# ---------------------------------------------------------------------
# LLM provider — manual §2.2 week 2 directive
# ---------------------------------------------------------------------
# Anthropic is the primary clinical-reasoning provider.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-5

# OpenAI is RAG-embeddings-only by default (set OPENAI_EMBED_MODEL to
# override). It can also serve as the prompt-path fallback when the
# Anthropic key is missing; the BAA tripwire below still applies.
OPENAI_API_KEY=sk-...
OPENAI_EMBED_MODEL=text-embedding-3-large
# Legacy single-provider knobs (kept so older deployments keep working).
LLM_API_KEY=sk-...
LLM_MODEL=claude-opus-4-5
LLM_API_URL=https://api.openai.com/v1/chat/completions

# ---------------------------------------------------------------------
# BAA tripwire — manual §7.2 Risk #1 mitigation
# ---------------------------------------------------------------------
# Set to 1 ONLY after Business Associate Agreements are filed with the
# LLM provider AND the customer tenant. While 0, any prompt that looks
# like real PHI (size > BUDDI_BAA_MAX_PROMPT_BYTES, or containing a
# <clinical_note>/<clinical_context> delimiter) is refused by
# core/llm_manager.py. See docs/COMPLIANCE/baa_status.md.
BUDDI_BAA_CONFIRMED=0
BUDDI_BAA_MAX_PROMPT_BYTES=200

# ---------------------------------------------------------------------
# Daily Merkle-root signing — manual §2.2 week 1 deliverable
# ---------------------------------------------------------------------
# Production: provision an Ed25519 key (preferably via GCP KMS / AWS
# KMS) and point this at the PEM file. The public half is published in
# docs/COMPLIANCE/ so external auditors can verify signed roots.
BUDDI_AUDIT_ROOT_SIGNING_KEY_PATH=
# Where signed daily envelopes are persisted. In production this should
# be a GCS / S3 bucket with Object Lock so the audit trail is
# append-only even if the DB is compromised.
BUDDI_AUDIT_ROOTS_DIR=storage/audit_roots
# Override the 24h cadence for dev / tests. Background task can be
# disabled entirely via BUDDI_DISABLE_MERKLE_TASK=1.
BUDDI_MERKLE_INTERVAL_SECONDS=86400
BUDDI_DISABLE_MERKLE_TASK=0

# ---------------------------------------------------------------------
# Agent safety floor — manual §7.2 Risk #2 mitigation
# ---------------------------------------------------------------------
# Suggestions with confidence < this floor are abstained rather than
# surfaced (recorded in the audit chain as hcc_suggestion_abstained).
# 0.70 is the starting placeholder; the eval harness in evals/ tunes
# this against a clinician-labeled golden set.
BUDDI_HCC_CONFIDENCE_FLOOR=0.70

# Optional: Tracing (skip for local dev)
OTLP_ENDPOINT=http://localhost:4318

# Optional: Behavior flags
DEV_MODE=false
# Security: BUDDI_TEST_MODE must never be set in production deployments.
BUDDI_TEST_MODE=0
ENABLE_RAG=true
ENABLE_TRACING=false
MEMORY_ENABLED=true
ENVIRONMENT=development

# Rate limiter (manual §4.2 Bottleneck #1) — set to 1 in CI / tests.
BUDDI_RATE_LIMIT_DISABLED=0
# Security: only these proxy CIDRs may provide X-Forwarded-For for rate limiting.
TRUSTED_PROXY_CIDRS=127.0.0.1/32

# Security: outbound FHIR calls are restricted to this comma-separated host allowlist.
ALLOWED_FHIR_HOSTS=127.0.0.1,localhost

# Security: credential JSON files are ignored; copy config/credentials.json.example locally.
GOOGLE_APPLICATION_CREDENTIALS=config/credentials.json

# Optional: Provider/runtime defaults
ASSISTANT_NAME=Buddi
ENABLE_EHR_READER=True
ENABLE_PRIOR_AUTH=True
ENABLE_CLINICAL_GUIDELINES=True
ENABLE_FOLLOW_UP=True
ENABLE_SCHEDULING=True
ENABLE_SAFETY_LAYER=True
ENABLE_AUDIT_LOG=True
REQUIRE_HUMAN_APPROVAL=True
AUDIT_LOG_FILE=audit_log.json
MAX_MEMORY_HISTORY=50
MEMORY_PERSIST_FILE=memory.json
USE_VOICE=False
FORCE_CPU=False
PREFERRED_DEVICE=auto
