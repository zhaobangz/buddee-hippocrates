# =====================================================================
# Buddi — environment template.
#
# Copy to `.env` and fill real values. Production systems must source
# these from a secrets manager (AWS Secrets Manager, GCP Secret Manager,
# HashiCorp Vault) — NEVER commit real values.
# =====================================================================

# --- MANDATORY SECURITY (SEC-03, SEC-05) -----------------------------
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# Master passphrase for at-rest PHI envelope encryption.
BUDDI_STORAGE_KEY=
# Static API-key for server-to-server auth. If empty, bearer-mode is used
# against SECRET_KEY. Generate the same way as SECRET_KEY.
API_KEY=

# --- CORS (SEC-01) ---------------------------------------------------
# Comma-separated list of exact origins the frontend may connect from.
# NEVER use "*" — that is actively rejected by backend.api.
CORS_ORIGINS=http://localhost:5173

# --- Database --------------------------------------------------------
# Local Docker quickstart:
#   docker run -d --name buddi-postgres \
#     -e POSTGRES_USER=buddi_user \
#     -e POSTGRES_PASSWORD=yourpassword \
#     -e POSTGRES_DB=buddi \
#     -p 5432:5432 ankane/pgvector
DATABASE_URL=postgresql://buddi_user:yourpassword@localhost:5432/buddi

# --- LLM -------------------------------------------------------------
LLM_PROVIDER=openai
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=gpt-4-turbo
OPENAI_API_KEY=

# --- Assistant Identity ---------------------------------------------
ASSISTANT_NAME=Buddi

# --- Healthcare Tools ------------------------------------------------
ENABLE_EHR_READER=True
ENABLE_PRIOR_AUTH=True
ENABLE_CLINICAL_GUIDELINES=True
ENABLE_FOLLOW_UP=True
ENABLE_SCHEDULING=True

# --- Safety & Compliance --------------------------------------------
ENABLE_SAFETY_LAYER=True
ENABLE_AUDIT_LOG=True
REQUIRE_HUMAN_APPROVAL=True
AUDIT_LOG_FILE=audit_log.json

# --- Memory ---------------------------------------------------------
MEMORY_ENABLED=True
MAX_MEMORY_HISTORY=50
MEMORY_PERSIST_FILE=memory.json

# --- Voice (optional) ------------------------------------------------
USE_VOICE=False

# --- Device ---------------------------------------------------------
FORCE_CPU=False
PREFERRED_DEVICE=auto

# --- Dev Mode (CFG-04) ---------------------------------------------
# Gate for development-only shortcuts. MUST remain `false` (or unset) in any
# production-shaped environment. docker-compose.yml reads this via
# `${DEV_MODE:-false}`.
DEV_MODE=false

