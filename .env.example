# Security (required — generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=changeme_min_32_chars
BUDDI_STORAGE_KEY=changeme_min_16_chars
API_KEY=changeme_api_key

# Database (required)
DATABASE_URL=postgresql://buddi_user:yourpassword@localhost:5432/buddi
# Optional override of the runtime DB role granted RLS privileges during
# the 7a3c8d9f0142 migration. Falls back to current_user when unset.
BUDDI_DB_ROLE=

# CORS (required — comma-separated, no wildcards)
CORS_ORIGINS=http://localhost:5173

# ---------------------------------------------------------------------
# LLM provider — manual §2.2 week 2 directive
# ---------------------------------------------------------------------
# Anthropic is the primary clinical-reasoning provider.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# Tier-based routing: Opus 4.8 for high-stakes reasoning (safety
# arbitration, prior-auth drafts), Sonnet 4.6 for high-volume HCC/ICD
# coding suggestions and free-text narration. Override to pin versions
# or route to a different model per tier.
ANTHROPIC_ROUTING_MODEL=claude-opus-4-8
ANTHROPIC_CODING_MODEL=claude-sonnet-4-6

# OpenAI is RAG-embeddings-only by default (set OPENAI_EMBED_MODEL to
# override). It can also serve as the prompt-path fallback when the
# Anthropic key is missing; the BAA tripwire below still applies.
OPENAI_API_KEY=sk-...
OPENAI_EMBED_MODEL=text-embedding-3-large
# Legacy single-provider knobs (kept so older deployments keep working).
LLM_API_KEY=sk-...
LLM_MODEL=claude-opus-4-8
LLM_API_URL=https://api.openai.com/v1/chat/completions

# ---------------------------------------------------------------------
# BAA tripwire — manual §7.2 Risk #1 mitigation
# ---------------------------------------------------------------------
# Set to 1 ONLY after Business Associate Agreements are filed with the
# LLM provider AND the customer tenant. While 0, any prompt that looks
# like real PHI (size > BUDDI_BAA_MAX_PROMPT_BYTES, or containing a
# <clinical_note>/<clinical_context> delimiter) is refused by
# core/llm_manager.py. See docs/COMPLIANCE/baa_status.md.
BUDDI_BAA_CONFIRMED=0
BUDDI_BAA_MAX_PROMPT_BYTES=200

# ---------------------------------------------------------------------
# Daily Merkle-root signing — manual §2.2 week 1 deliverable
# ---------------------------------------------------------------------
# Signer resolution priority: Cloud KMS -> local Ed25519 PEM -> dev HMAC.
#
# PRODUCTION (recommended): back the signing key with an HSM via Cloud KMS.
# The private key never leaves the HSM; the public half is embedded in every
# signed envelope so auditors verify OFFLINE (no KMS call). Set provider + key:
#   * GCP: provider=gcp, key=projects/<p>/locations/<l>/keyRings/<r>/cryptoKeys/<k>/cryptoKeyVersions/<n>
#   * AWS: provider=aws, key=<KMS key id, alias, or ARN>  (uses AWS_REGION)
# Supported KMS key algorithms: EC P-256/P-384 (recommended) or RSA-PKCS1.
# Requires the matching SDK installed (google-cloud-kms or boto3).
BUDDI_AUDIT_KMS_PROVIDER=
BUDDI_AUDIT_KMS_KEY=
# Alternative to KMS: path to a self-managed PEM-encoded Ed25519 private key.
# The public half is published in docs/COMPLIANCE/ for external auditors.
BUDDI_AUDIT_ROOT_SIGNING_KEY_PATH=
# Where signed daily envelopes are persisted locally (canonical read path).
BUDDI_AUDIT_ROOTS_DIR=storage/audit_roots
# Object Lock (WORM) mirror. When set, each signed envelope is ALSO written
# to this bucket with Object Lock retention, giving an append-only archive
# that survives full host/DB compromise. Provision the bucket retention
# policy via IaC; these vars control the per-object retention request.
#   s3://<bucket>/<prefix>   (requires boto3 + AWS_REGION)
#   gs://<bucket>/<prefix>   (requires google-cloud-storage)
BUDDI_AUDIT_ROOTS_BUCKET=
# COMPLIANCE (immutable, cannot be shortened by anyone) or GOVERNANCE.
BUDDI_AUDIT_OBJECT_LOCK_MODE=COMPLIANCE
# Per-object retention in days. Default ~7 years, beyond the HIPAA 6-year floor.
BUDDI_AUDIT_OBJECT_LOCK_DAYS=2555
# Override the 24h cadence for dev / tests. Background task can be
# disabled entirely via BUDDI_DISABLE_MERKLE_TASK=1.
BUDDI_MERKLE_INTERVAL_SECONDS=86400
BUDDI_DISABLE_MERKLE_TASK=0

# ---------------------------------------------------------------------
# Agent safety floor — manual §7.2 Risk #2 mitigation
# ---------------------------------------------------------------------
# Suggestions with confidence < this floor are abstained rather than
# surfaced (recorded in the audit chain as hcc_suggestion_abstained).
# 0.70 is the starting placeholder; the eval harness in evals/ tunes
# this against a clinician-labeled golden set.
BUDDI_HCC_CONFIDENCE_FLOOR=0.70

# ---------------------------------------------------------------------
# Eval regression gate — manual §2.2 / §7.2 Risk #2 (build-out A2)
# ---------------------------------------------------------------------
# Absolute precision/recall floors for `python -m evals.run_eval`. When
# > 0, the run exits non-zero if top-3-code precision or recall on the
# golden set falls below the floor (in addition to the relative
# regression gate vs evals/baseline.json). Left at 0.0 (disabled) for
# the deterministic offline CI run whose demo-fallback baseline is
# intentionally low; set both to 0.60 for the real-LLM nightly run.
EVAL_PRECISION_FLOOR=0.0
EVAL_RECALL_FLOOR=0.0

# ---------------------------------------------------------------------
# Adversarial red-team alerting (build-out C1) — nightly suite
# ---------------------------------------------------------------------
# On a red-team failure, evals/red_team/run_red_team.py emails ALERT_EMAIL
# via SMTP (best-effort; no-op if ALERT_SMTP_HOST is unset). Optionally point
# BUDDI_RED_TEAM_BASE_URL at a live deployment for a real-LLM jailbreak run.
ALERT_EMAIL=
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=
BUDDI_RED_TEAM_BASE_URL=

# Optional: Tracing (skip for local dev)
OTLP_ENDPOINT=http://localhost:4318

# Optional: Behavior flags
DEV_MODE=false
# Security: BUDDI_TEST_MODE must never be set in production deployments.
BUDDI_TEST_MODE=0
ENABLE_RAG=true
ENABLE_TRACING=false
MEMORY_ENABLED=true
ENVIRONMENT=development

# Rate limiter (manual §4.2 Bottleneck #1) — set to 1 in CI / tests.
BUDDI_RATE_LIMIT_DISABLED=0
# Security: only these proxy CIDRs may provide X-Forwarded-For for rate limiting.
# Startup refuses world routes (0.0.0.0/0 or ::/0) outside development (QW-2).
TRUSTED_PROXY_CIDRS=127.0.0.1/32

# C-1 (Cloud Run only): directory of file-mounted secrets. core/secrets_loader.py
# maps known filenames to env vars at boot (see infra/env.tier2.example).
# Leave unset for local dev.
SECRETS_DIR=

# C-2: emergency break-glass — disables PHI/BAA enforcement. Requires BOTH
# flags set to "disabled" AND a future BUDDI_BREAKGLASS_UNTIL ISO-8601
# timestamp AND, in production, BUDDI_ALLOW_PROD_BREAKGLASS=1. Every
# activation logs CRITICAL. Never set outside an active incident.
BUDDI_PHI_PROCESSING_ENFORCEMENT=
BUDDI_BAA_INGEST_ENFORCEMENT=
BUDDI_BREAKGLASS_UNTIL=

# H-4: LLM client timeout (seconds) for the reasoning tier. Default 90.
BUDDI_LLM_TIMEOUT_SECONDS=90

# ---------------------------------------------------------------------
# Async job worker (build-out B3) — strategy-doc §4.2 Bottleneck #3
# ---------------------------------------------------------------------
# /api/shadow/audit and /api/prior-auth/generate enqueue an LLM-bound job and
# return 202; a worker drains the queue (run standalone: python -m core.worker).
# Set to 1 in Cloud Run buddi-api; the worker runs as a separate buddi-worker service.
BUDDI_DISABLE_WORKER=0
# Legacy alias for BUDDI_DISABLE_WORKER, still honored by the API lifespan.
BUDDI_DISABLE_JOB_WORKER=0
# I-1: idle-queue poll backoff ceiling (seconds). The worker polls at
# BUDDI_WORKER_POLL_INTERVAL (default 2s) and backs off exponentially to
# this max while the queue is empty. Default 30.
BUDDI_WORKER_POLL_MAX_INTERVAL=30
# Seconds the worker sleeps between polls when the jobs queue is idle.
BUDDI_WORKER_POLL_INTERVAL=2

# ---------------------------------------------------------------------
# Hosted synthetic-FHIR demo (build-out A3) — no PHI, served pre-BAA
# ---------------------------------------------------------------------
# Directory of the broader 25-bundle synthetic corpus served at
# /api/demo/synthea (also the Synthea-generator drift-check target).
BUDDI_SYNTHEA_DIR=evals/synthea/bundles
# Directory of the committed 5-bundle demo fixture set served at
# /api/demo/bundles and used as the _demo_shadow_result note source.
BUDDI_DEMO_FIXTURES_DIR=evals/synthea/fixtures

# ---------------------------------------------------------------------
# SMART-on-FHIR EHR connector (build-out B1) — strategy-doc §2.1 gap #2
# ---------------------------------------------------------------------
# OAuth2 client registered with the EHR / SMART sandbox. CLIENT_SECRET is
# blank for public (PKCE-only) clients. SMART_FHIR_BASE_URL defaults to the
# SMART Health IT public sandbox R4 endpoint for dev/staging.
SMART_CLIENT_ID=
SMART_CLIENT_SECRET=
SMART_REDIRECT_URI=http://localhost:8001/api/ehr/callback
SMART_FHIR_BASE_URL=https://launch.smarthealthit.org/v/r4/fhir
# Where /api/ehr/callback redirects the operator after a successful connect.
SMART_DASHBOARD_REDIRECT=/dashboard

# ---------------------------------------------------------------------
# Stripe billing (build-out B5) — strategy-doc §2.1 gap #10
# ---------------------------------------------------------------------
# Billing endpoints return HTTP 503 ("not configured") until these are set.
# No PHI is ever sent to Stripe (tenant name/email + tenant_id metadata only).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...   # your $250-400/physician/month price ID
STRIPE_PRICE_ID_GAIN_SHARE=price_... # optional 15-20% gain-share price
# Optional hosted-page redirects for Checkout / billing portal.
STRIPE_SUCCESS_URL=https://app.buddi.health/billing?status=success
STRIPE_CANCEL_URL=https://app.buddi.health/billing?status=cancel
STRIPE_PORTAL_RETURN_URL=https://app.buddi.health/billing

# Security: outbound FHIR calls are restricted to this comma-separated host allowlist.
ALLOWED_FHIR_HOSTS=127.0.0.1,localhost

# Security: credential JSON files are ignored; copy config/credentials.json.example locally.
GOOGLE_APPLICATION_CREDENTIALS=config/credentials.json

# Optional: Provider/runtime defaults
ASSISTANT_NAME=Buddi
ENABLE_EHR_READER=True
ENABLE_PRIOR_AUTH=True
ENABLE_CLINICAL_GUIDELINES=True
ENABLE_FOLLOW_UP=True
ENABLE_SCHEDULING=True
ENABLE_SAFETY_LAYER=True
ENABLE_AUDIT_LOG=True
REQUIRE_HUMAN_APPROVAL=True
AUDIT_LOG_FILE=audit_log.json
MAX_MEMORY_HISTORY=50
MEMORY_PERSIST_FILE=memory.json
USE_VOICE=False
FORCE_CPU=False
PREFERRED_DEVICE=auto
