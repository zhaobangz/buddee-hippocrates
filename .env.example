# Security (required — generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=changeme_min_32_chars
BUDDI_STORAGE_KEY=changeme_min_16_chars
API_KEY=changeme_api_key

# Database (required)
DATABASE_URL=postgresql://buddi_user:yourpassword@localhost:5432/buddi

# CORS (required — comma-separated, no wildcards)
CORS_ORIGINS=http://localhost:5173

# LLM (required for real AI features; leave blank to use demo stubs)
OPENAI_API_KEY=sk-...
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o

# Optional: Anthropic (preferred for clinical reasoning)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Tracing (skip for local dev)
OTLP_ENDPOINT=http://localhost:4318

# Optional: Behavior flags
DEV_MODE=false
# Security: BUDDI_TEST_MODE must never be set in production deployments.
BUDDI_TEST_MODE=0
ENABLE_RAG=true
ENABLE_TRACING=false
MEMORY_ENABLED=true
ENVIRONMENT=development

# Security: only these proxy CIDRs may provide X-Forwarded-For for rate limiting.
TRUSTED_PROXY_CIDRS=127.0.0.1/32

# Security: outbound FHIR calls are restricted to this comma-separated host allowlist.
ALLOWED_FHIR_HOSTS=127.0.0.1,localhost

# Security: credential JSON files are ignored; copy config/credentials.json.example locally.
GOOGLE_APPLICATION_CREDENTIALS=config/credentials.json

# Optional: Provider/runtime defaults
LLM_PROVIDER=openai
LLM_API_URL=https://api.openai.com/v1/chat/completions
ASSISTANT_NAME=Buddi
ENABLE_EHR_READER=True
ENABLE_PRIOR_AUTH=True
ENABLE_CLINICAL_GUIDELINES=True
ENABLE_FOLLOW_UP=True
ENABLE_SCHEDULING=True
ENABLE_SAFETY_LAYER=True
ENABLE_AUDIT_LOG=True
REQUIRE_HUMAN_APPROVAL=True
AUDIT_LOG_FILE=audit_log.json
MAX_MEMORY_HISTORY=50
MEMORY_PERSIST_FILE=memory.json
USE_VOICE=False
FORCE_CPU=False
PREFERRED_DEVICE=auto

