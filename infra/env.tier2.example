# Buddi Tier 2 — GCP PHI‑tier environment configuration.
#
# Copy to infra/env.tier2 (gitignored) and fill in every field before
# running infra/provision_gcp.sh. This file documents every placeholder
# that appears in cloud-run-*.yaml.
#
# ═══════════════════════════════════════════════════════════════════
# ⛔  BAAs MUST BE SIGNED BEFORE PROVISIONING THIS TIER.
#    See docs/COMPLIANCE/baa_status.md — every Required‑BAA row must
#    say ``signed: yes`` before BUDDI_BAA_CONFIRMED can flip to 1.
# ═══════════════════════════════════════════════════════════════════

# ---- Project -------------------------------------------------------
GCP_PROJECT_ID=buddi-prod-xxxx
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# ---- Networking ----------------------------------------------------
# VPC connector for Cloud Run → Cloud SQL private IP access.
# Created by provision_gcp.sh; must match the name in cloud-run-*.yaml.
VPC_CONNECTOR_NAME=buddi-vpc

# ---- Cloud SQL (Postgres 16 + pgvector) ----------------------------
# Instance tier: start at db-g1-small for pilot (1.7 GB RAM, $25/mo);
# bump to db-custom-2-7680 when patient volume grows.
CLOUDSQL_INSTANCE=buddi-prod
CLOUDSQL_TIER=db-g1-small
CLOUDSQL_DB=buddi
CLOUDSQL_USER=buddi_app
# CMEK key for Cloud SQL (must be provisioned first):
CLOUDSQL_CMEK_KEY=projects/${GCP_PROJECT_ID}/locations/${GCP_REGION}/keyRings/buddi-prod/cryptoKeys/cloudsql-cmek

# ---- Cloud KMS (Merkle‑root signing) -------------------------------
# Key ring + signing key for daily Merkle‑root signatures.
# Algorithm: EC_P256_SHA256 (recommended) or RSA_SIGN_PKCS1_2048_SHA256.
KMS_KEY_RING=buddi-prod
KMS_KEY_RING_LOCATION=us-central1
KMS_SIGNING_KEY=buddi-merkle-signing
KMS_SIGNING_KEY_ALGORITHM=EC_SIGN_P256_SHA256

# ---- Cloud Storage (Object Lock WORM audit archive) -----------------
# Bucket for signed Merkle‑root exports. COMPLIANCE mode Object Lock
# with 2555‑day retention (~7 years, beyond HIPAA 6‑year floor).
AUDIT_BUCKET=buddi-audit-roots-prod
AUDIT_BUCKET_LOCATION=US
AUDIT_OBJECT_LOCK_DAYS=2555

# ---- Secret Manager -------------------------------------------------
# Names of secrets created by provision_gcp.sh. Values are set
# interactively or via gcloud secrets versions add.
SECRET_NAME_DATABASE_URL=buddi-database-url
SECRET_NAME_SECRET_KEY=buddi-secret-key
SECRET_NAME_STORAGE_KEY=buddi-storage-key
SECRET_NAME_API_KEY=buddi-api-key
SECRET_NAME_ANTHROPIC_KEY=buddi-anthropic-key

# ---- Memorystore Redis (rate limiter + job queue) -------------------
# Minimal instance for pilot; bump to M2 for >10 tenants.
REDIS_INSTANCE=buddi-redis-prod
REDIS_TIER=standard
REDIS_SIZE_GB=1

# ---- Service accounts -------------------------------------------------
# Created by provision_gcp.sh with least‑priv IAM:
#   buddi-api@     — Cloud Run API service identity
#   buddi-worker@  — Cloud Run worker service identity
#   buddi-migrate@ — Cloud Run Job migration runner identity
API_SA=buddi-api
WORKER_SA=buddi-worker
MIGRATE_SA=buddi-migrate

# ---- Artifact Registry ----------------------------------------------
AR_REPO=buddi
AR_LOCATION=us-central1

# ---- Cloud Run ------------------------------------------------------
# Service names (must match cloud-run-*.yaml metadata.name).
CLOUD_RUN_API_SERVICE=buddi-api
CLOUD_RUN_WORKER_SERVICE=buddi-worker
CLOUD_RUN_MIGRATE_JOB=buddi-migrate-prod
