{
  "displayName": "Buddi — SLO Dashboard",
  "dashboardFilters": [],
  "mosaicLayout": {
    "columns": 12,
    "tiles": [
      {
        "title": "Shadow Audit — p95 Latency (target: <30s)",
        "width": 6,
        "height": 4,
        "widget": {
          "title": "shadow_audit_p95_latency",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"run.googleapis.com/request_latencies\" resource.type=\"cloud_run_revision\" resource.label.service_name=\"buddi-api\" metric.label.path=\"/api/shadow/audit\"",
                    "aggregation": {
                      "perSeriesAligner": "ALIGN_PERCENTILE_95",
                      "alignmentPeriod": "300s"
                    }
                  }
                },
                "plotType": "LINE",
                "legendTemplate": "p95 latency"
              }
            ],
            "chartOptions": {"mode": "COLOR"},
            "timeshiftDuration": "0s",
            "yAxis": {"label": "seconds"}
          }
        }
      },
      {
        "title": "Audit Chain — Verify Rate (target: 100%)",
        "width": 6,
        "height": 4,
        "widget": {
          "title": "audit_chain_verify_rate",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"logging.googleapis.com/user/buddi_audit_verify\" metric.label.status=\"verified\"",
                    "aggregation": {
                      "perSeriesAligner": "ALIGN_COUNT",
                      "alignmentPeriod": "3600s"
                    }
                  }
                },
                "plotType": "LINE",
                "legendTemplate": "verified count"
              }
            ],
            "chartOptions": {"mode": "COLOR"},
            "timeshiftDuration": "0s",
            "yAxis": {"label": "events"}
          }
        }
      },
      {
        "title": "Error Rate — All Endpoints (target: <0.5%)",
        "width": 6,
        "height": 4,
        "widget": {
          "title": "error_rate",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"run.googleapis.com/request_count\" resource.type=\"cloud_run_revision\" resource.label.service_name=\"buddi-api\" metric.label.response_code_class=\"5xx\"",
                    "aggregation": {
                      "perSeriesAligner": "ALIGN_RATE",
                      "alignmentPeriod": "300s"
                    }
                  }
                },
                "plotType": "LINE",
                "legendTemplate": "5xx rate"
              }
            ],
            "chartOptions": {"mode": "COLOR"},
            "timeshiftDuration": "0s",
            "yAxis": {"label": "errors/s"}
          }
        }
      },
      {
        "title": "LLM Provider — Error/429 Rate (target: <1%)",
        "width": 6,
        "height": 4,
        "widget": {
          "title": "llm_error_rate",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"logging.googleapis.com/user/buddi_llm_request\" metric.label.outcome=monitoring.regexFullMatch(\"(error|429)\")",
                    "aggregation": {
                      "perSeriesAligner": "ALIGN_COUNT",
                      "alignmentPeriod": "600s"
                    }
                  }
                },
                "plotType": "LINE",
                "legendTemplate": "LLM errors/429s"
              }
            ],
            "chartOptions": {"mode": "COLOR"},
            "timeshiftDuration": "0s",
            "yAxis": {"label": "count"}
          }
        }
      },
      {
        "title": "Prior Auth — p95 Latency (target: <10s)",
        "width": 6,
        "height": 4,
        "widget": {
          "title": "prior_auth_p95_latency",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"run.googleapis.com/request_latencies\" resource.type=\"cloud_run_revision\" resource.label.service_name=\"buddi-api\" metric.label.path=\"/api/prior-auth/generate\"",
                    "aggregation": {
                      "perSeriesAligner": "ALIGN_PERCENTILE_95",
                      "alignmentPeriod": "300s"
                    }
                  }
                },
                "plotType": "LINE",
                "legendTemplate": "p95 latency"
              }
            ],
            "chartOptions": {"mode": "COLOR"},
            "timeshiftDuration": "0s",
            "yAxis": {"label": "seconds"}
          }
        }
      }
    ]
  }
}
