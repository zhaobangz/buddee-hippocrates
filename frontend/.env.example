# Backend API base URL. Set to your deployed Render/Fly URL in production.
# VITE_API_BASE_URL is also recognized (alias); VITE_API_BASE takes precedence.
VITE_API_BASE=http://localhost:8001/api
# Static API key shared with the backend (optional; prompt-on-401 fallback).
VITE_API_KEY=your_api_key_here
