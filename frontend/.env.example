# Buddi frontend environment template.
# Copy to `.env.local` (gitignored) and adjust per environment.
#
# Track 1 / Step 1 (FE-01, CFG-01): all frontend API traffic is routed through
# `VITE_API_BASE`. The canonical backend is `backend.api:app` on port 8001.

# Local dev (matches start_dev.py / docker-compose.yml defaults)
VITE_API_BASE=http://localhost:8001/api

# Staging
# VITE_API_BASE=https://api.staging.buddi.example.com/api

# Production
# VITE_API_BASE=https://api.buddi.example.com/api
